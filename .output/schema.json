{
    "$defs": {
        "ContainerConfig": {
            "properties": {
                "services": {
                    "description": "Services in this container",
                    "patternProperties": {
                        "^[a-zA-Z0-9_]+$": {
                            "$ref": "#/$defs/ContainerServiceConfig"
                        }
                    },
                    "title": "Services",
                    "type": "object"
                },
                "cpuLimit": {
                    "default": 0.5,
                    "description": "CPU limit to apply to the generated Docker Compose service",
                    "exclusiveMinimum": 0,
                    "title": "Cpulimit",
                    "type": "number"
                }
            },
            "required": [
                "services"
            ],
            "title": "ContainerConfig",
            "type": "object"
        },
        "ContainerServiceConfig": {
            "properties": {
                "canRestart": {
                    "description": "Whether the service can restart",
                    "title": "Canrestart",
                    "type": "boolean"
                }
            },
            "required": [
                "canRestart"
            ],
            "title": "ContainerServiceConfig",
            "type": "object"
        },
        "DependencyConfig": {
            "properties": {
                "callRate": {
                    "description": "Call rate as a decimal between 0 and 1",
                    "maximum": 1.0,
                    "minimum": 0.0,
                    "title": "Callrate",
                    "type": "number"
                },
                "stopOnError": {
                    "description": "Whether to stop on error",
                    "title": "Stoponerror",
                    "type": "boolean"
                }
            },
            "required": [
                "callRate",
                "stopOnError"
            ],
            "title": "DependencyConfig",
            "type": "object"
        },
        "MicroserviceConfig": {
            "properties": {
                "dependencies": {
                    "description": "Dependencies of this microservice",
                    "patternProperties": {
                        "^[a-zA-Z0-9_]+$": {
                            "$ref": "#/$defs/DependencyConfig"
                        }
                    },
                    "title": "Dependencies",
                    "type": "object"
                },
                "errorRate": {
                    "description": "Error rate as a decimal between 0 and 1",
                    "maximum": 1.0,
                    "minimum": 0.0,
                    "title": "Errorrate",
                    "type": "number"
                },
                "workDifficulty": {
                    "description": "Work difficulty level",
                    "minimum": 0.0,
                    "title": "Workdifficulty",
                    "type": "number"
                },
                "delay": {
                    "default": 0,
                    "description": "Delay in milliseconds",
                    "minimum": 0,
                    "title": "Delay",
                    "type": "integer"
                }
            },
            "required": [
                "dependencies",
                "errorRate",
                "workDifficulty"
            ],
            "title": "MicroserviceConfig",
            "type": "object"
        },
        "ServiceConfig": {
            "properties": {
                "entrypoint": {
                    "anyOf": [
                        {
                            "pattern": "^[a-zA-Z0-9_]+$",
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "Name of the microservice to call at the beginning of a request; if omitted, the service can act as a client that only calls dependent services",
                    "title": "Entrypoint"
                },
                "dependencies": {
                    "description": "Services called by this service in order",
                    "patternProperties": {
                        "^[a-zA-Z0-9_]+$": {
                            "$ref": "#/$defs/DependencyConfig"
                        }
                    },
                    "title": "Dependencies",
                    "type": "object"
                },
                "microservices": {
                    "description": "Microservices in this service",
                    "patternProperties": {
                        "^[a-zA-Z0-9_]+$": {
                            "$ref": "#/$defs/ServiceMicroserviceConfig"
                        }
                    },
                    "title": "Microservices",
                    "type": "object"
                }
            },
            "title": "ServiceConfig",
            "type": "object"
        },
        "ServiceMicroserviceConfig": {
            "properties": {
                "canRestart": {
                    "description": "Whether the microservice can restart",
                    "title": "Canrestart",
                    "type": "boolean"
                }
            },
            "required": [
                "canRestart"
            ],
            "title": "ServiceMicroserviceConfig",
            "type": "object"
        }
    },
    "properties": {
        "entrypoint": {
            "anyOf": [
                {
                    "pattern": "^[a-zA-Z0-9_]+$",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ],
            "default": null,
            "description": "Root service called by external requests",
            "title": "Entrypoint"
        },
        "requestCount": {
            "default": 100,
            "description": "Default number of requests to use when testing the generated architecture",
            "minimum": 1,
            "title": "Requestcount",
            "type": "integer"
        },
        "logLevel": {
            "default": "INFO",
            "description": "Default logging level for the shared application logger",
            "enum": [
                "DEBUG",
                "INFO",
                "WARNING",
                "ERROR",
                "CRITICAL"
            ],
            "title": "Loglevel",
            "type": "string"
        },
        "microservices": {
            "description": "All microservices in the simulation",
            "patternProperties": {
                "^[a-zA-Z0-9_]+$": {
                    "$ref": "#/$defs/MicroserviceConfig"
                }
            },
            "title": "Microservices",
            "type": "object"
        },
        "services": {
            "description": "All services in the simulation",
            "patternProperties": {
                "^[a-zA-Z0-9_]+$": {
                    "$ref": "#/$defs/ServiceConfig"
                }
            },
            "title": "Services",
            "type": "object"
        },
        "containers": {
            "description": "All containers in the simulation",
            "patternProperties": {
                "^[a-zA-Z0-9_]+$": {
                    "$ref": "#/$defs/ContainerConfig"
                }
            },
            "title": "Containers",
            "type": "object"
        }
    },
    "required": [
        "microservices",
        "services",
        "containers"
    ],
    "title": "SimulationConfig",
    "type": "object"
}