{
    "$schema": "./.output/schema.json",
    "microservices": {
        "Auth": {
            "dependencies": {
                "User": {
                    "callRate": 1,
                    "stopOnError": true
                }
            },
            "errorRate": 0.002,
            "workDifficulty": 0.2,
            "delay": 4
        },
        "User": {
            "dependencies": {},
            "errorRate": 0.001,
            "workDifficulty": 0.15,
            "delay": 2
        },
        "Catalog": {
            "dependencies": {
                "Stock": {
                    "callRate": 1,
                    "stopOnError": false
                }
            },
            "errorRate": 0.003,
            "workDifficulty": 0.5,
            "delay": 8
        },
        "Stock": {
            "dependencies": {},
            "errorRate": 0.001,
            "workDifficulty": 0.4,
            "delay": 5
        },
        "Payment": {
            "dependencies": {
                "Auth": {
                    "callRate": 1,
                    "stopOnError": true
                }
            },
            "errorRate": 0.004,
            "workDifficulty": 0.6,
            "delay": 10
        }
    },
    "services": {
        "IdentityService": {
            "microservices": {
                "Auth": {
                    "canRestart": true
                },
                "User": {
                    "canRestart": true
                }
            }
        },
        "CommerceService": {
            "microservices": {
                "Catalog": {
                    "canRestart": true
                },
                "Stock": {
                    "canRestart": true
                },
                "Payment": {
                    "canRestart": false
                }
            }
        }
    },
    "containers": {
        "ContainerA": {
            "services": {
                "IdentityService": {
                    "canRestart": true
                }
            }
        },
        "ContainerB": {
            "services": {
                "CommerceService": {
                    "canRestart": true
                }
            }
        }
    }
}
